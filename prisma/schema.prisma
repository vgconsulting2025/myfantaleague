// MyFantaLeague — schema dati (SQLite via Prisma).
// La lega demo viene creata dallo script prisma/seed.ts.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Team {
  id             String   @id @default(cuid())
  slug           String   @unique
  name           String
  president      String
  points         Int      @default(0)
  isUser         Boolean  @default(false)
  players        Player[]
  createdAt      DateTime @default(now())
  // Identità squadra (file statici referenziati, colori sociali)
  crestUrl       String?
  jerseyFrontUrl String?
  jerseyBackUrl  String?
  color1         String?
  color2         String?
  // Giocatore idolo della squadra + tracciamento progressi.
  // Base estendibile per futuri livelli/skin (nessuna FK: idolPlayerId risolto a mano).
  idolPlayerId    String? // id del giocatore designato idolo (null = nessuno)
  idolSetGiornata Int? // giornata dell'ultima designazione (vincolo: 1 cambio per giornata)
  idolCumFm       Float   @default(0) // fantamedia cumulata giornata per giornata mentre idolo
  idolBestCount   Int     @default(0) // giornate da migliore in campo della squadra
  idolStreak      Int     @default(0) // giornate consecutive da idolo senza cambio
  idolLevel       Int     @default(1) // livello progressione idolo (1 Bronzo .. 4 Leggenda)
  idolQuote       String? // citazione "da tifoso" (solo livello Leggenda)
  // Rivale storico: una squadra della lega scelta come rivale + storico derby.
  rivalTeamId        String? // id della squadra rivale (nessuna FK: risolto a mano)
  rivalSetGiornata   Int? // giornata dell'ultima scelta (vincolo: 1 cambio per giornata)
  rivalWins          Int   @default(0) // vittorie nei derby contro il rivale corrente
  rivalDraws         Int   @default(0) // pareggi nei derby
  rivalLosses        Int   @default(0) // sconfitte nei derby
  rivalPointsFor     Float @default(0) // punteggio totale della squadra nei derby
  rivalPointsAgainst Float @default(0) // punteggio totale del rivale nei derby
  rivalDerbies       Int   @default(0) // numero di derby giocati
}

model Player {
  id       String  @id @default(cuid())
  name     String
  role     String // P | D | C | A
  club     String
  quota    Int
  fm       Float
  imageUrl String? // immagine personalizzata caricata dall'utente (file statico)
  number   Int? // numero di maglia (editabile; default automatico 1-99)
  team     Team?   @relation(fields: [teamId], references: [id], onDelete: Cascade)
  teamId   String? // null = giocatore svincolato

  @@index([teamId])
}

model Giornata {
  id           String        @id @default(cuid())
  number       Int           @unique
  playedAt     DateTime      @default(now())
  results      Result[]
  performances Performance[]
  coachRatings CoachRating[]
  peerVotes    PeerVote[]
}

// Prestazione di un giocatore in una giornata (voto + bonus) e se schierato.
model Performance {
  id         String   @id @default(cuid())
  giornata   Giornata @relation(fields: [giornataId], references: [id], onDelete: Cascade)
  giornataId String
  teamName   String
  president  String
  playerName String
  role       String
  vote       Float
  bonus      Float    @default(0)
  fielded    Boolean

  @@index([giornataId])
}

// Voto AI (1-10) all'allenatore per una giornata, con commento goliardico.
model CoachRating {
  id         String   @id @default(cuid())
  giornata   Giornata @relation(fields: [giornataId], references: [id], onDelete: Cascade)
  giornataId String
  teamName   String
  president  String
  score      Int
  comment    String
  createdAt  DateTime @default(now())

  @@index([giornataId])
  @@index([teamName])
}

// Voto tra presidenti (identità = teamName). Un team non può votare se stesso.
model PeerVote {
  id         String   @id @default(cuid())
  giornata   Giornata @relation(fields: [giornataId], references: [id], onDelete: Cascade)
  giornataId String
  fromTeam   String
  toTeam     String
  score      Int
  comment    String   @default("")
  hidden     Boolean  @default(false)
  createdAt  DateTime @default(now())

  @@index([toTeam])
  @@index([giornataId])
}

model Result {
  id         String   @id @default(cuid())
  giornata   Giornata @relation(fields: [giornataId], references: [id], onDelete: Cascade)
  giornataId String
  homeName   String
  awayName   String
  homeScore  Float
  awayScore  Float
  note       String

  @@index([giornataId])
}

model Edition {
  id        String    @id @default(cuid())
  createdAt DateTime  @default(now())
  giornata  Int?
  articles  Article[]
}

model Article {
  id        String   @id @default(cuid())
  edition   Edition? @relation(fields: [editionId], references: [id], onDelete: Cascade)
  editionId String? // null = notizia singola (non parte di un'edizione)
  kicker    String
  title     String
  body      String
  category  String
  isLead    Boolean  @default(false)
  order     Int      @default(0)
  createdAt DateTime @default(now())

  @@index([editionId])
  @@index([createdAt])
}

// Configurazione della lega (singleton, id = "league").
model LeagueConfig {
  id                  String  @id @default("league")
  gazzettaName        String  @default("MyFantaGazzetta")
  freeAgentEnabled    Boolean @default(true)
  freeAgentMaxPerWeek Int     @default(2)
}

// Proposta di scambio 1-per-1 tra un giocatore di una squadra e uno svincolato,
// generata automaticamente dall'Agente.
model FreeAgentProposal {
  id           String   @id @default(cuid())
  createdAt    DateTime @default(now())
  status       String   @default("pending") // pending | accepted | rejected
  teamName     String
  giveName     String
  giveRole     String
  giveQuota    Int
  giveFm       Float
  faName       String
  faRole       String
  faClub       String
  faQuota      Int
  faFm         Float
  rationale    String
  agentComment String
  forUser      Boolean  @default(false)

  @@index([status])
}

model Trade {
  id           String   @id @default(cuid())
  createdAt    DateTime @default(now())
  status       String // accepted | rejected
  fromTeam     String
  toTeam       String
  giveName     String
  receiveName  String
  rationale    String
  agentComment String
}

model FlashNews {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  text      String
  kind      String   @default("mercato") // mercato | generic
}
